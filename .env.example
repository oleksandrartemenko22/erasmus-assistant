# .env.example — copy to .env.local and fill in real values

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key          # safe for browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key       # server-only, never expose

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Admin panel ───────────────────────────────────────────────────────────────
# Shared secret for admin API routes. Generate with: openssl rand -hex 32
ADMIN_SECRET=change-this-to-a-long-random-string

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
